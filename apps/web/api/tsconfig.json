{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "baseUrl": "..",
    "paths": {
      "@/*": ["./src/*"],
      "@serenity/shared": ["../../packages/shared/src/index.ts"],
      "@serenity/shared/*": ["../../packages/shared/src/*"]
    },
    "types": ["node"]
  },
  "include": [
    "./**/*.ts",
    "../../../mcp-server/src/**/*.ts",
    "../../../packages/shared/src/**/*.ts",
    "../src/shared/**/*.ts",
    "../src/types/**/*.ts"
  ]
}
