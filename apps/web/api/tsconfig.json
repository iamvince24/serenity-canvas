{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "baseUrl": "..",
    "paths": {
      "@/*": ["./src/*"],
      "@serenity/shared": ["../../packages/shared/src/index.ts"],
      "@serenity/shared/*": ["../../packages/shared/src/*"],
      "@serenity/mcp-server": ["../mcp-server/src/server.ts"],
      "@serenity/mcp-server/*": ["../mcp-server/src/*"]
    },
    "types": ["node"]
  },
  "include": ["./**/*.ts", "../src/shared/**/*.ts", "../src/types/**/*.ts"]
}
