{
  "name": "@serenity/mcp-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./heightEstimator": {
      "types": "./dist/heightEstimator.d.ts",
      "import": "./dist/heightEstimator.js"
    }
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@serenity/shared": "workspace:*",
    "@supabase/supabase-js": "^2.98.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.19.4",
    "typescript": "~5.9.3"
  }
}
