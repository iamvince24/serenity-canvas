{
  "name": "serenity-canvas",
  "private": true,
  "version": "0.0.0",
  "description": "An elegant visual whiteboard tool.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:mcp": "tsc -p mcp-server/tsconfig.json",
    "mcp:dev": "tsx mcp-server/src/index.ts",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit && tsc -p e2e/tsconfig.json --noEmit && tsc -p api/tsconfig.json --noEmit",
    "lint": "eslint . && pnpm typecheck",
    "preview": "vite preview",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:pull": "supabase db pull",
    "db:migration:new": "supabase migration new",
    "db:types": "supabase gen types typescript --local > src/types/supabase.ts",
    "db:types:remote": "supabase gen types typescript --project-id nsxvydduqdpeedrfdyuz > src/types/supabase.ts"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix",
      "vitest related --run"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tiptap/core": "^2.14.0",
    "@tiptap/extension-task-item": "^2.14.0",
    "@tiptap/extension-task-list": "^2.14.0",
    "@tiptap/pm": "^2.14.0",
    "@tiptap/react": "^2.14.0",
    "@tiptap/starter-kit": "^2.14.0",
    "@tiptap/suggestion": "^2.27.2",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "comlink": "^4.4.2",
    "dexie": "^4",
    "i18next": "^25.8.14",
    "i18next-browser-languagedetector": "^8.2.1",
    "jszip": "^3.10.1",
    "konva": "^10.2.0",
    "lucide-react": "^0.572.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.4",
    "react-konva": "^19.2.2",
    "react-router": "^7.13.0",
    "sanitize-filename": "^1.6.3",
    "tailwind-merge": "^3.4.1",
    "tailwindcss": "^4.1.18",
    "zod": "^3.25.67",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "tsc-alias": "^1.8.15",
    "tsx": "^4.19.4",
    "@eslint/js": "^9.39.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "fake-indexeddb": "^6.2.5",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "@playwright/test": "^1.58.2",
    "prettier": "^3.8.1",
    "shadcn": "^3.8.5",
    "supabase": "^2.76.15",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
