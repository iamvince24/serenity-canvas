{
  "name": "serenity-canvas-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "An elegant visual whiteboard tool.",
  "type": "module",
  "packageManager": "pnpm@9.6.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "build:mcp": "tsc -p mcp-server/tsconfig.json",
    "mcp:dev": "tsx mcp-server/src/index.ts",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "preview": "pnpm -C apps/web preview",
    "prepare": "husky",
    "test": "turbo test",
    "test:watch": "pnpm -C apps/web test:watch",
    "test:coverage": "pnpm -C apps/web test:coverage",
    "e2e": "pnpm -C apps/web e2e",
    "e2e:ui": "pnpm -C apps/web e2e:ui",
    "e2e:headed": "pnpm -C apps/web e2e:headed",
    "e2e:report": "pnpm -C apps/web e2e:report",
    "db:start": "pnpm -C apps/web db:start",
    "db:stop": "pnpm -C apps/web db:stop",
    "db:reset": "pnpm -C apps/web exec supabase db reset",
    "db:push": "pnpm -C apps/web exec supabase db push",
    "db:pull": "pnpm -C apps/web exec supabase db pull",
    "db:migration:new": "pnpm -C apps/web run db:migration:new",
    "db:types": "pnpm -C apps/web run db:types",
    "db:types:remote": "pnpm -C apps/web run db:types:remote"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "**/*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@serenity/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@types/node": "^24.10.1",
    "@supabase/supabase-js": "^2.98.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "turbo": "^2.0.0",
    "tsx": "^4.19.4",
    "typescript": "~5.9.3",
    "zod": "^3.25.67"
  }
}
